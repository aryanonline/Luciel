{
    "family": "luciel-mint",
    "taskRoleArn": "arn:aws:iam::729005488042:role/luciel-ecs-mint-role",
    "executionRoleArn": "arn:aws:iam::729005488042:role/luciel-ecs-execution-role",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "containerDefinitions": [
        {
            "name": "luciel-backend",
            "image": "729005488042.dkr.ecr.ca-central-1.amazonaws.com/luciel-backend@sha256:3275322b7ef80a508680dced0ed4a142de77b0d3fd984318878bc57157ff7b95",
            "essential": true,
            "command": [
                "python",
                "-m",
                "scripts.mint_worker_db_password_ssm"
            ],
            "environment": [
                {
                    "name": "WORKER_HOST",
                    "value": "luciel-db.c3oyiegi01hr.ca-central-1.rds.amazonaws.com"
                },
                {
                    "name": "WORKER_DB_NAME",
                    "value": "luciel"
                },
                {
                    "name": "WORKER_SSM_PATH",
                    "value": "/luciel/production/worker_database_url"
                },
                {
                    "name": "MINT_DRY_RUN",
                    "value": "true"
                }
            ],
            "secrets": [
                {
                    "name": "ADMIN_DSN",
                    "valueFrom": "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/database-url"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/luciel-backend",
                    "awslogs-region": "ca-central-1",
                    "awslogs-stream-prefix": "mint"
                }
            }
        }
    ]
}
