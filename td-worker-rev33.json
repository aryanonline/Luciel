{
    "containerDefinitions":  [
                                 {
                                     "name":  "luciel-worker",
                                     "image":  "729005488042.dkr.ecr.ca-central-1.amazonaws.com/luciel-backend@sha256:b4c145eb3f876f30fec947e7d58080c570eabf5ddce587815eb28d98214c4dff",
                                     "cpu":  0,
                                     "portMappings":  [

                                                      ],
                                     "essential":  true,
                                     "command":  [
                                                     "celery",
                                                     "-A",
                                                     "app.worker.celery_app",
                                                     "worker",
                                                     "--beat",
                                                     "--loglevel=info",
                                                     "-Q",
                                                     "luciel-memory-tasks",
                                                     "--concurrency=2",
                                                     "--without-gossip",
                                                     "--without-mingle",
                                                     "--without-heartbeat"
                                                 ],
                                     "environment":  [
                                                         {
                                                             "name":  "MEMORY_EXTRACTION_ASYNC",
                                                             "value":  "true"
                                                         },
                                                         {
                                                             "name":  "CELERY_BROKER_URL",
                                                             "value":  "sqs://"
                                                         },
                                                         {
                                                             "name":  "AWS_REGION",
                                                             "value":  "ca-central-1"
                                                         }
                                                     ],
                                     "mountPoints":  [

                                                     ],
                                     "volumesFrom":  [

                                                     ],
                                     "secrets":  [
                                                     {
                                                         "name":  "ANTHROPIC_API_KEY",
                                                         "valueFrom":  "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/anthropic-api-key"
                                                     },
                                                     {
                                                         "name":  "DATABASE_URL",
                                                         "valueFrom":  "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/production/worker_database_url"
                                                     },
                                                     {
                                                         "name":  "OPENAI_API_KEY",
                                                         "valueFrom":  "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/openai-api-key"
                                                     },
                                                     {
                                                         "name":  "REDIS_URL",
                                                         "valueFrom":  "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/production/REDIS_URL"
                                                     },
                                                     {
                                                         "valueFrom":  "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/production/jwt_signing_keys_json",
                                                         "name":  "JWT_SIGNING_KEYS_JSON"
                                                     },
                                                     {
                                                         "valueFrom":  "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/production/jwt_active_kid",
                                                         "name":  "JWT_ACTIVE_KID"
                                                     },
                                                     {
                                                         "valueFrom":  "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/production/jwt_grace_kid",
                                                         "name":  "JWT_GRACE_KID"
                                                     }
                                                 ],
                                     "logConfiguration":  {
                                                              "logDriver":  "awslogs",
                                                              "options":  {
                                                                              "awslogs-group":  "/ecs/luciel-worker",
                                                                              "awslogs-region":  "ca-central-1",
                                                                              "awslogs-stream-prefix":  "worker"
                                                                          }
                                                          },
                                     "healthCheck":  {
                                                         "command":  [
                                                                         "CMD-SHELL",
                                                                         "python3 /app/scripts/healthcheck_worker.py"
                                                                     ],
                                                         "interval":  30,
                                                         "timeout":  15,
                                                         "retries":  3,
                                                         "startPeriod":  60
                                                     },
                                     "systemControls":  [

                                                        ]
                                 }
                             ],
    "family":  "luciel-worker",
    "taskRoleArn":  "arn:aws:iam::729005488042:role/luciel-ecs-worker-role",
    "executionRoleArn":  "arn:aws:iam::729005488042:role/luciel-ecs-execution-role",
    "networkMode":  "awsvpc",
    "volumes":  [

                ],
    "placementConstraints":  [

                             ],
    "runtimePlatform":  {
                            "cpuArchitecture":  "X86_64",
                            "operatingSystemFamily":  "LINUX"
                        },
    "requiresCompatibilities":  [
                                    "FARGATE"
                                ],
    "cpu":  "512",
    "memory":  "1024"
}
