    "test:e2e": "npm run build && node scripts/e2e-smoke.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  }
}
