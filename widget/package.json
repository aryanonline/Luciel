{
  "name": "@luciel/chat-widget",
  "version": "0.1.0",
  "description": "Luciel embeddable chat widget. Preact + TypeScript. Single ESM, <=40 KB gzipped.",
  "type": "module",
  "private": true,
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "size": "node scripts/check-bundle-size.mjs",
