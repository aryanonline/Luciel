{
    "family": "luciel-verify",
    "taskRoleArn": "arn:aws:iam::729005488042:role/luciel-ecs-verify-role",
    "executionRoleArn": "arn:aws:iam::729005488042:role/luciel-ecs-execution-role",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "containerDefinitions": [
        {
            "name": "luciel-verify",
            "image": "729005488042.dkr.ecr.ca-central-1.amazonaws.com/luciel-backend@sha256:46f24f0b8b1a94f325780af6ba58bb5d50b877688a9729c7d48a701ea3a12539",
            "essential": true,
            "command": [
                "python",
                "-m",
                "app.verification",
                "--json-report",
                "/tmp/report.json"
            ],
            "environment": [
                {
                    "name": "LUCIEL_BASE_URL",
                    "value": "https://api.vantagemind.ai"
                },
                {
                    "name": "AWS_REGION",
                    "value": "ca-central-1"
                }
            ],
            "secrets": [
                {
                    "name": "LUCIEL_PLATFORM_ADMIN_KEY",
                    "valueFrom": "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/production/platform-admin-key"
                },
                {
                    "name": "DATABASE_URL",
                    "valueFrom": "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/production/worker_database_url"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/luciel-backend",
                    "awslogs-region": "ca-central-1",
                    "awslogs-stream-prefix": "verify"
                }
            }
        }
    ]
}
