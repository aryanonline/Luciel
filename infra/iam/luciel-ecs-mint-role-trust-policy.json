{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": {
                "Service": "ecs-tasks.amazonaws.com"
            },
            "Action": "sts:AssumeRole",
            "Condition": {
                "StringEquals": {
                    "aws:SourceAccount": "729005488042"
                },
                "ArnLike": {
                    "aws:SourceArn": "arn:aws:ecs:ca-central-1:729005488042:*"
                }
            }
        }
    ]
}
