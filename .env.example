# Luciel backend — example local-dev env. Production reads these
# values from SSM via the ECS task-def `secrets:` block, NOT from a
# .env file. See app/core/config.py for the canonical setting names
# and defaults. Anything not listed here uses its config.py default.

# --- Required for boot ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/luciel

# --- LLM providers (optional in dev; backend boots without keys) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Redis (Celery broker + Arc 12 BYO circuit breaker state) ---
# Prod task-defs inject this from SSM /luciel/production/REDIS_URL.
# Arc 12 WU6 reuses this same URL for the per-endpoint circuit
# breaker (app/tools/byo/circuit_breaker.py); no new Redis resource
# is required for Arc 12.
REDIS_URL=redis://localhost:6379/0
