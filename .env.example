# Luciel backend — example local-dev env. Production reads these
# values from SSM via the ECS task-def `secrets:` block, NOT from a
# .env file. See app/core/config.py for the canonical setting names
# and defaults. Anything not listed here uses its config.py default.

# --- Required for boot ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/luciel

# --- LLM providers (optional in dev; backend boots without keys) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Redis (Celery broker + Arc 12 BYO circuit breaker state) ---
# Prod task-defs inject this from SSM /luciel/production/REDIS_URL.
# Arc 12 WU6 reuses this same URL for the per-endpoint circuit
# breaker (app/tools/byo/circuit_breaker.py); no new Redis resource
# is required for Arc 12.
REDIS_URL=redis://localhost:6379/0

# --- Twilio SMS (Arc 13; optional in dev, routes fail closed 501) ---
# Prod injects these from SSM /luciel/production/twilio_*. Per-instance
# number purchase is on-demand (Admin toggle); these are the platform
# credentials the purchase + message paths authenticate with.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# --- luciel-mail.com inbound email + SES inbound infra (Arc 13) ---
# MAIL_INBOUND_DOMAIN and SES_INBOUND_BUCKET have safe code defaults;
# SES_INBOUND_TOPIC_ARN is empty in dev (TopicArn trust gate disabled).
# Prod injects the bucket + topic ARN from SSM /luciel/production/.
MAIL_INBOUND_DOMAIN=luciel-mail.com
SES_INBOUND_BUCKET=
SES_INBOUND_TOPIC_ARN=
