{
  "family": "luciel-backend",
  "taskRoleArn": "arn:aws:iam::729005488042:role/luciel-ecs-web-role",
  "executionRoleArn": "arn:aws:iam::729005488042:role/luciel-ecs-execution-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "luciel-backend",
      "image": "729005488042.dkr.ecr.ca-central-1.amazonaws.com/luciel-backend@sha256:bf0259387cbf65c9b83dea35339f908754f34c81e9a0a8de564f9790ccdcfc36",
      "cpu": 0,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp",
          "name": "luciel-backend-8000-tcp"
        }
      ],
      "environment": [
        { "name": "MEMORY_EXTRACTION_ASYNC", "value": "true" },
        { "name": "CELERY_BROKER_URL", "value": "sqs://" },
        { "name": "AWS_REGION", "value": "ca-central-1" }
      ],
      "secrets": [
        { "name": "ANTHROPIC_API_KEY", "valueFrom": "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/anthropic-api-key" },
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/database-url" },
        { "name": "OPENAI_API_KEY", "valueFrom": "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/openai-api-key" },
        { "name": "REDIS_URL", "valueFrom": "arn:aws:ssm:ca-central-1:729005488042:parameter/luciel/production/REDIS_URL" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/luciel-backend",
          "awslogs-region": "ca-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
